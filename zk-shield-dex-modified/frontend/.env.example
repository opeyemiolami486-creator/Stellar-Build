# ZK Shield DEX — Frontend Environment Variables
# Copy to .env.local

# Backend API URL
# Local dev: http://localhost:3001
# Railway/production: https://your-backend-service.up.railway.app
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Stellar network (always testnet for this MVP)
NEXT_PUBLIC_NETWORK=testnet

# Stellar Testnet USDC issuer (Railway frontend env)
NEXT_PUBLIC_TESTNET_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# ── ZK Shield DEX — Backend Environment ─────────────────────────────────────

# Port (default 3001)
PORT=3001

# Frontend origin for CORS (comma-separated if multiple)
# For local dev: http://localhost:3000
# For Railway: https://your-frontend-service.up.railway.app
FRONTEND_URL=http://localhost:3000

# Optional extra origins (comma-separated)
# ALLOWED_ORIGINS=https://your-frontend-service.up.railway.app,https://another-origin.com

# ── Stellar Testnet ───────────────────────────────────────────────────────────
# Relayer keypair — pays gas and executes trades on behalf of ZK-verified users.
# Generate: node -e "const{Keypair}=require('@stellar/stellar-sdk');const kp=Keypair.random();console.log('Secret:',kp.secret(),'\\nPublic:',kp.publicKey())"
# Fund via Friendbot: https://friendbot.stellar.org/?addr=YOUR_PUBLIC_KEY
RELAYER_SECRET_KEY=

# ── Soroban Contract ──────────────────────────────────────────────────────────
# Deploy with: ./deploy-contract.sh (requires Stellar CLI + funded account)
# Leave blank to get a clear error — do NOT use "DEMO_MODE" or fake values.
CONTRACT_ID=

# Optional Stellar Testnet USDC issuer; configure if USDC support is required.
# For the official testnet USDC issuer, use:
# TESTNET_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
TESTNET_USDC_ISSUER=

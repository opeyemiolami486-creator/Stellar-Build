# ── ZK Shield DEX — Backend Environment ─────────────────────────────────────

# Port (default 3001)
PORT=3001

# Frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# ── Stellar Testnet ───────────────────────────────────────────────────────────
# Relayer keypair — pays gas and executes trades on behalf of ZK-verified users.
# Generate: node -e "const{Keypair}=require('@stellar/stellar-sdk');const kp=Keypair.random();console.log('Secret:',kp.secret(),'\\nPublic:',kp.publicKey())"
# Fund via Friendbot: https://friendbot.stellar.org/?addr=YOUR_PUBLIC_KEY
RELAYER_SECRET_KEY=

# ── Soroban Contract ──────────────────────────────────────────────────────────
# Deploy with: ./deploy-contract.sh (requires Stellar CLI + funded account)
# Leave blank to get a clear error — do NOT use "DEMO_MODE" or fake values.
CONTRACT_ID=
